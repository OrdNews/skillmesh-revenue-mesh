PORT=3000
SKILLMESH_MODE=prototype

# X Layer
# Mainnet RPC from official X Layer docs:
# https://rpc.xlayer.tech
# Testnet RPC if needed during development:
# https://testrpc.xlayer.tech
XLAYER_RPC_URL=https://rpc.xlayer.tech
SKILLMESH_REGISTRY_ADDRESS=
SKILLMESH_RECEIPT_ADDRESS=
ONCHAINOS_ACCOUNT_ID=
SCOUT_ACCOUNT_ID=
TRADER_ACCOUNT_ID=
TREASURY_ACCOUNT_ID=

# Onchain OS / x402
OK_API_KEY=
OK_SECRET_KEY=
OKX_PASSPHRASE=
# x402 API base inferred from the official OKX x402 docs and API reference:
# supported: GET {base}/supported
# verify:    POST {base}/verify
# settle:    POST {base}/settle
X402_FACILITATOR_URL=https://web3.okx.com/api/v6/x402

# Uniswap AI route planning is modeled in code in the local scaffold.
# Add provider-specific env vars here later if you wire a hosted route service.

# Wallets
ORCHESTRATOR_PRIVATE_KEY=
TREASURY_PRIVATE_KEY=
